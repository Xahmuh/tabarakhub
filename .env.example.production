# Dedicated-client production frontend environment.
# Copy to .env.production for one private client installation.
# Do not commit real values.

# Supabase public frontend values for this client's dedicated Supabase project.
VITE_SUPABASE_URL=https://PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=PUBLIC_ANON_KEY_HERE

# Client branding and safe frontend configuration.
VITE_APP_NAME="Operations Hub"
VITE_CLIENT_NAME="CLIENT_NAME_HERE"
VITE_CLIENT_LOGO_URL="/logo.jpg"
VITE_PRIMARY_COLOR="#B91c1c"
VITE_PRIMARY_HOVER_COLOR="#991b1b"
VITE_PRIMARY_DARK_COLOR="#7f1d1d"
VITE_PRIMARY_MUTED_COLOR="rgba(185, 28, 28, 0.05)"
VITE_ACCENT_COLOR="#0f172a"
VITE_SUPPORT_EMAIL="CLIENT_SUPPORT_EMAIL_HERE"
VITE_DEFAULT_LOCALE="en"
VITE_CURRENCY="BHD"
VITE_COUNTRY="Bahrain"
VITE_ENVIRONMENT_LABEL="production"
VITE_DEMO_MODE=false

# Optional HR Google Apps Script integration.
# This is a public browser-called endpoint only. Do not put secrets in the URL or payload.
# For production, prefer routing HR integrations through a trusted server/Supabase Function.
VITE_HR_GOOGLE_SCRIPT_URL=""

# Module flags. Use false to hide/disable a module for this dedicated client.
VITE_MODULE_HR=true
VITE_MODULE_QUALITY_FEEDBACK=true
VITE_MODULE_AI_INSIGHTS=false
VITE_MODULE_REPORTS=true
VITE_MODULE_EXCEL_EXPORT=true
VITE_MODULE_BRANCH_DASHBOARD=true
VITE_MODULE_MANAGER_DASHBOARD=true
VITE_MODULE_ADMIN_DASHBOARD=true
VITE_MODULE_PRODUCTS=true
VITE_MODULE_SALES=true
VITE_MODULE_SPIN_WIN=true
VITE_MODULE_CASH_FLOW=true
VITE_MODULE_CASH_TRACKER=true
VITE_MODULE_CORPORATE_CODEX=true
VITE_MODULE_EMPLOYEE_CONTRIBUTIONS=true
VITE_MODULE_SETTINGS=true
VITE_MODULE_WORKFORCE=true
VITE_MODULE_DELIVERY=true
# Advanced Delivery Coverage analytics (campaign engine, catchment, overlap, capacity, expansion review).
VITE_DELIVERY_COVERAGE_ADVANCED_ANALYTICS=true

# Never expose service_role keys in frontend env files.
# SUPABASE_SERVICE_ROLE_KEY belongs only in trusted server/Edge Function secrets.
# FUNCTION_SECRET must be configured with Supabase secrets, not VITE_ env:
# supabase secrets set FUNCTION_SECRET="use-a-long-random-secret"
#
# Server-only Edge Function secrets/config, set with `supabase secrets set`.
# Do not prefix these with VITE_ and do not expose them to the browser:
# SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY
# FUNCTION_SECRET
# ALLOWED_ORIGIN or CLIENT_APP_URL
# RESEND_API_KEY
# REPORT_FROM_EMAIL
# NOTIFICATION_FROM_EMAIL
# ADMIN_EMAIL
# CEO_EMAIL
# CLIENT_DASHBOARD_URL
# CLIENT_PUBLIC_NAME
# AI_INSIGHTS_ENABLED
# ANTHROPIC_API_KEY
# Email functions reject placeholder/example emails and require an HTTPS CLIENT_DASHBOARD_URL.
# Driver QA credentials must live only in ignored local env files during a test run.
